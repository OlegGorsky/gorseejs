{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "jsxImportSource": "gorsee",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "types": ["bun"],
    "paths": {
      "gorsee": ["../../src/index.ts"],
      "gorsee/jsx-runtime": ["../../src/jsx-runtime.ts"],
      "gorsee/jsx-dev-runtime": ["../../src/jsx-runtime.ts"],
      "gorsee/*": ["../../src/*/index.ts"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["node_modules", "dist"]
}
